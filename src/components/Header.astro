---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeSelector from './ThemeSelector.astro';

interface Props {
	transparent?: boolean;
}

const { transparent = false } = Astro.props;
---

<header class:list={[{ 'header--transparent': transparent }]} data-transparent={transparent ? 'true' : undefined}>
	<nav>
		<div class="nav-links">
			<HeaderLink href="/">Blog</HeaderLink>
			<HeaderLink href="/work">Work</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="site-identity">
			<a href="/" class="site-title">{SITE_TITLE}</a>
			<div class="social-links">
				<a href="https://linkedin.com/in/jimjeffers" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
				</a>
				<a href="https://twitter.com/jimjeffers" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
				<ThemeSelector />
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background-color: rgb(var(--color-bg));
		padding: 1rem 1.5rem;
		transition: background-color 0.25s ease-out, color 0.25s ease-out, backdrop-filter 0.25s ease-out;
	}
	header.header--transparent {
		background-color: color-mix(in srgb, var(--project-bg, rgb(var(--color-bg))) 82%, transparent);
		color: var(--project-fg, rgb(var(--color-text)));
		backdrop-filter: blur(14px) saturate(1.2);
		-webkit-backdrop-filter: blur(14px) saturate(1.2);
	}
	header.header--transparent.is-scrolled {
		background-color: rgb(var(--color-bg));
		color: inherit;
		backdrop-filter: none;
		-webkit-backdrop-filter: none;
	}
	header.header--transparent .social-links a,
	header.header--transparent :global(.nav-links a),
	header.header--transparent :global(.theme-trigger) {
		color: var(--project-muted, rgb(var(--color-text-secondary)));
		transition: color 0.25s ease-out;
	}
	header.header--transparent .social-links a:hover,
	header.header--transparent :global(.nav-links a.active),
	header.header--transparent :global(.nav-links a:hover),
	header.header--transparent :global(.theme-trigger:hover) {
		color: var(--project-fg, rgb(var(--color-text)));
	}
	header.header--transparent.is-scrolled .social-links a,
	header.header--transparent.is-scrolled :global(.nav-links a),
	header.header--transparent.is-scrolled :global(.theme-trigger) {
		color: rgb(var(--color-text-secondary));
	}
	header.header--transparent.is-scrolled .social-links a:hover,
	header.header--transparent.is-scrolled :global(.nav-links a.active),
	header.header--transparent.is-scrolled :global(.nav-links a:hover),
	header.header--transparent.is-scrolled :global(.theme-trigger:hover) {
		color: rgb(var(--color-text));
	}
	@media (min-width: 768px) {
		header {
			padding: 1.5rem 3rem;
		}
	}
	@media (min-width: 1200px) {
		header {
			padding: 2rem 6rem;
		}
		header::after {
			content: '';
			position: absolute;
			bottom: -3rem;
			left: 0;
			right: 0;
			height: 3rem;
			background: linear-gradient(to bottom, rgb(var(--color-bg)), transparent);
			pointer-events: none;
			opacity: 1;
			transition: opacity 0.25s ease-out;
		}
		header.header--transparent::after {
			opacity: 0;
		}
		header.header--transparent.is-scrolled::after {
			opacity: 1;
		}
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.site-identity {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.25rem;
	}
	.site-title {
		font-family: 'Jost', system-ui, sans-serif;
		font-size: 1.125rem;
		font-weight: var(--header-weight);
		text-decoration: none;
	}
	.site-title:hover {
		background-color: transparent;
	}
	.social-links {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	.social-links a {
		color: rgb(var(--color-text-secondary));
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.social-links a:hover {
		color: rgb(var(--color-text));
		background-color: transparent;
	}
	.nav-links {
		display: flex;
		gap: 1.5rem;
	}
</style>

<script>
	const header = document.querySelector('header[data-transparent="true"]') as HTMLElement | null;
	if (header) {
		const hero = document.querySelector('.project-hero') as HTMLElement | null;
		const getThreshold = () => {
			if (!hero) return 0;
			return hero.offsetTop + hero.offsetHeight - header.offsetHeight;
		};
		let threshold = getThreshold();
		const update = () => {
			header.classList.toggle('is-scrolled', window.scrollY >= threshold);
		};
		window.addEventListener('scroll', update, { passive: true });
		window.addEventListener('resize', () => {
			threshold = getThreshold();
			update();
		});
		update();
	}
</script>
