---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, role, client, stack, startDate, endDate, externalUrl, screenshots, tags } = Astro.props;

function formatYear(date: Date) {
  return date.getFullYear();
}

const dateLabel = endDate
  ? `${formatYear(startDate)}–${formatYear(endDate)}`
  : `${formatYear(startDate)}–Present`;
---

<html lang="en">
  <head>
    <BaseHead title={`${title} — Jim Jeffers`} description={description} />
    <style>
      article {
        max-width: 40rem;
        margin: 0;
        padding: 0 0 3rem;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.875rem;
        color: rgb(var(--color-text-secondary));
        text-decoration: none;
        margin-bottom: 2.5rem;
        transition: color 0.1s ease-out;
      }
      .back-link:hover {
        color: rgb(var(--color-text));
        background-color: transparent;
      }
      .post-header {
        margin-bottom: 2rem;
      }
      .post-header h1 {
        margin-bottom: 0.5rem;
      }
      .post-meta {
        color: rgb(var(--color-text-secondary));
        font-size: 0.875rem;
        margin: 0 0 0.75rem;
      }
      .post-meta span {
        margin-right: 0.25rem;
      }
      .meta-separator {
        opacity: 0.5;
        margin-right: 0.25rem;
      }
      .external-link {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.875rem;
        color: rgb(var(--color-text-secondary));
        margin-bottom: 1.5rem;
        transition: color 0.1s ease-out;
      }
      .external-link:hover {
        color: rgb(var(--color-text));
        background-color: transparent;
      }
      .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        list-style: none;
        margin: 0 0 2rem;
        padding: 0;
      }
      .stack-tag {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 0.25em;
        background-color: rgb(var(--color-text) / 0.06);
        color: rgb(var(--color-text-secondary));
        font-family: Consolas, Monaco, monospace;
      }
      .project-body {
        line-height: 1.7;
      }
      .project-body h2 {
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        font-size: 1.375rem;
      }
      .project-body h3 {
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-size: 1.125rem;
      }
      .project-body ul,
      .project-body ol {
        margin: 0 0 1.5em 0;
        padding-left: 1.5em;
      }
      .project-body ul { list-style: disc; }
      .project-body ol { list-style: decimal; }
      .project-body li {
        margin-bottom: 0.4em;
      }
      .project-body li::marker {
        color: rgb(var(--color-accent));
      }
      .project-body strong {
        font-weight: 700;
        color: rgb(var(--color-text));
      }
      .screenshot-gallery {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        margin: 0 0 2.5rem;
        padding-bottom: 0.5rem;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
      }
      .screenshot-gallery img {
        height: 28rem;
        width: auto;
        border-radius: 1rem;
        flex-shrink: 0;
        display: block;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <a href="/work" class="back-link">← Work</a>

        <div class="post-header">
          <h1>{title}</h1>
          <p class="post-meta">
            <span>{role}</span>
            <span class="meta-separator">·</span>
            <span>{dateLabel}</span>
            {client && (
              <>
                <span class="meta-separator">·</span>
                <span>{client}</span>
              </>
            )}
          </p>
        </div>

        {externalUrl && (
          <a href={externalUrl} class="external-link" target="_blank" rel="noopener noreferrer">
            {new URL(externalUrl).hostname} ↗
          </a>
        )}

        <ul class="stack-list" aria-label="Tech stack">
          {stack.map((tech) => (
            <li class="stack-tag">{tech}</li>
          ))}
        </ul>

        {screenshots && screenshots.length > 0 && (
          <div class="screenshot-gallery" role="region" aria-label="App screenshots">
            {screenshots.map((src, i) => (
              <img src={src} alt={`${title} screenshot ${i + 1}`} loading="lazy" />
            ))}
          </div>
        )}

        <div class="project-body">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
