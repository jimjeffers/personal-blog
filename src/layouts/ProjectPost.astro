---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'portfolio'>['data'];

const { title, description, role, client, stack, startDate, endDate, externalUrl, tags } = Astro.props;

function formatYear(date: Date) {
  return date.getFullYear();
}

const dateLabel = endDate
  ? `${formatYear(startDate)}–${formatYear(endDate)}`
  : `${formatYear(startDate)}–Present`;
---

<html lang="en">
  <head>
    <BaseHead title={`${title} — Jim Jeffers`} description={description} />
    <style>
      article {
        max-width: 40rem;
        margin: 0;
        padding: 0 0 3rem;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.875rem;
        color: rgb(var(--color-text-secondary));
        text-decoration: none;
        margin-bottom: 2.5rem;
        transition: color 0.1s ease-out;
      }
      .back-link:hover {
        color: rgb(var(--color-text));
        background-color: transparent;
      }
      .project-header {
        margin-bottom: 2rem;
      }
      .project-header h1 {
        margin-bottom: 0.5rem;
      }
      .project-client {
        color: rgb(var(--color-text-secondary));
        font-size: 0.9375rem;
        margin: 0 0 1.25rem;
      }
      .project-meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem 2rem;
        margin-bottom: 1.5rem;
        padding: 1.25rem 0;
        border-top: 1px solid rgb(var(--color-border));
        border-bottom: 1px solid rgb(var(--color-border));
      }
      @media (max-width: 480px) {
        .project-meta-grid {
          grid-template-columns: 1fr;
        }
      }
      .meta-item {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .meta-label {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgb(var(--color-text-secondary));
        font-family: 'Jost', system-ui, sans-serif;
        font-weight: var(--header-weight);
        opacity: 0.7;
      }
      .meta-value {
        font-size: 0.9375rem;
        color: rgb(var(--color-text));
      }
      .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .stack-tag {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        background-color: rgb(var(--color-text) / 0.06);
        color: rgb(var(--color-text-secondary));
        font-family: Consolas, Monaco, monospace;
        transition: background-color 0.1s ease-out;
      }
      .external-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.9375rem;
        color: rgb(var(--color-text-secondary));
        margin-top: 0.25rem;
      }
      .external-link:hover {
        color: rgb(var(--color-text));
      }
      .project-body {
        line-height: 1.7;
      }
      .project-body h2 {
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        font-size: 1.375rem;
      }
      .project-body h3 {
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        font-size: 1.125rem;
      }
      .project-body ul,
      .project-body ol {
        margin: 0 0 1.5em 0;
        padding-left: 1.5em;
      }
      .project-body ul { list-style: disc; }
      .project-body ol { list-style: decimal; }
      .project-body li {
        margin-bottom: 0.4em;
      }
      .project-body li::marker {
        color: rgb(var(--color-accent));
      }
      .project-body strong {
        font-weight: 700;
        color: rgb(var(--color-text));
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <a href="/work" class="back-link">← Work</a>

        <div class="project-header">
          <h1>{title}</h1>
          {client && <p class="project-client">{client}</p>}
        </div>

        <div class="project-meta-grid">
          <div class="meta-item">
            <span class="meta-label">Role</span>
            <span class="meta-value">{role}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Timeline</span>
            <span class="meta-value">{dateLabel}</span>
          </div>
          <div class="meta-item" style="grid-column: 1 / -1">
            <span class="meta-label">Stack</span>
            <ul class="stack-list">
              {stack.map((tech) => (
                <li class="stack-tag">{tech}</li>
              ))}
            </ul>
          </div>
          {externalUrl && (
            <div class="meta-item">
              <span class="meta-label">Link</span>
              <a href={externalUrl} class="external-link" target="_blank" rel="noopener noreferrer">
                {new URL(externalUrl).hostname} ↗
              </a>
            </div>
          )}
        </div>

        <div class="project-body">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
